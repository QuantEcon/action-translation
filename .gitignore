node_modules/

# Build output
# dist/ — ESM build from tsc (not committed, rebuild with `npm run build:cli`)
dist/
# dist-action/ — esbuild CJS bundle for GitHub Actions (committed, rebuild with `npm run build`)
# Keep dist-action/ tracked; only ignore its node_modules
dist-action/node_modules/

# Tool build outputs (standalone tools don't need committed builds)
tool-test-action-on-github/evaluate/dist/

*.log
.env
.DS_Store
coverage/
docs/_build/
.vscode/
.idea/

# TypeScript build info
*.tsbuildinfo

# Scratch — .dev/scratch/ dir is committed (via .gitkeep) but contents are ignored
.dev/scratch/*
!.dev/scratch/.gitkeep
# Legacy scratch location (retired 2026-07-05; see .dev/decisions/) — keep ignoring stale local copies
.tmp/
**/*.tmp
.cache/

# Generated reports (output of CLI tools)
/reports/

# Test repositories (cloned locally for testing)
test-translation-sync/
test-translation-sync.zh-cn/
test-translation-sync.fa/
tool-test-action-on-github/test-translation-sync/
tool-test-action-on-github/test-translation-sync.zh-cn/
tool-test-action-on-github/test-translation-sync.fa/
