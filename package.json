{
  "name": "action-translation",
  "version": "0.11.0",
  "type": "module",
  "description": "GitHub Action to sync and review translations across repositories",
  "main": "dist/index.js",
  "bin": {
    "translate": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && node build-action.mjs",
    "build:cli": "tsc",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "github-action",
    "translation",
    "sync",
    "review",
    "myst",
    "markdown"
  ],
  "author": "QuantEcon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/QuantEcon/action-translation.git"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@anthropic-ai/sdk": "^0.78.0",
    "chalk": "^4.1.2",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "ink": "^4.4.1",
    "js-yaml": "^4.1.0",
    "react": "^18.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/jest": "^29.5.10",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@types/react": "^18.3.28",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "esbuild": "^0.27.3",
    "eslint": "^8.54.0",
    "ink-testing-library": "^4.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  }
}
